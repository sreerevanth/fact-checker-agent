# =============================================================================
# Real-Time Fact-Checking Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# --- LLM Providers ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here          # Optional fallback

# --- Primary Model ---
PRIMARY_MODEL=claude-sonnet-4-20250514            # Main reasoning model
EMBEDDING_MODEL=all-MiniLM-L6-v2                  # Local sentence-transformer
MAX_TOKENS=4096
TEMPERATURE=0.1                                    # Low temp for factual tasks

# --- News APIs ---
NEWSAPI_KEY=your_newsapi_key_here                  # https://newsapi.org
GNEWS_API_KEY=your_gnews_key_here                  # https://gnews.io (optional)
MEDIASTACK_API_KEY=your_mediastack_key_here        # https://mediastack.com (optional)

# --- Social Media APIs (optional) ---
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# --- Cache / Storage ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600                             # 1 hour default

# --- Vector DB ---
FAISS_INDEX_PATH=./data/faiss_index
FAISS_DIMENSION=384                                # Match embedding model dim

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false                                   # true for dev only

# --- Rate Limiting ---
MAX_REQUESTS_PER_MINUTE=60
SCRAPER_CONCURRENCY=5
RETRIEVAL_TOP_K=10                                 # Docs to retrieve per query

# --- Trusted Sources ---
TRUSTED_SOURCES_CONFIG=./config/trusted_sources.yaml

# --- Logging ---
LOG_LEVEL=INFO                                     # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                                    # json | console

# --- Monitoring ---
ENABLE_METRICS=true
METRICS_PORT=9090
